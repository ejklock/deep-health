{
  "name": "deep-health",
  "version": "0.1.6",
  "description": "CLI tool for automated vulnerability scanning and safe dependency updates",
  "type": "module",
  "bin": {
    "deep-health": "./dist/bin/deep-health.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx bin/deep-health.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.9",
    "prompts": "^2.4.2",
    "semver": "^7.6.3",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.5.8",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}